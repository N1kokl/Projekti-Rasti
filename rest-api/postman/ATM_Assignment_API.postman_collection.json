{
  "info": {
    "_postman_id": "2c0e2b0c-1b6b-4e3a-9cf7-90bcb7c90cf0",
    "name": "ATM Assignment API (book + car CRUD)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "GET all books",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/books"
          }
        },
        {
          "name": "GET book by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/books/{{bookId}}"
          }
        },
        {
          "name": "POST create book",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Refactoring\",\n  \"author\": \"Martin Fowler\",\n  \"isbn\": \"9780201485677\"\n}"
            },
            "url": "{{baseUrl}}/api/books"
          }
        },
        {
          "name": "PUT update book",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Refactoring (2nd Edition)\",\n  \"author\": \"Martin Fowler\",\n  \"isbn\": \"9780134757599\"\n}"
            },
            "url": "{{baseUrl}}/api/books/{{bookId}}"
          }
        },
        {
          "name": "DELETE book",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/books/{{bookId}}"
          }
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "GET all cars",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cars"
          }
        },
        {
          "name": "GET car by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cars/{{carId}}"
          }
        },
        {
          "name": "POST create car",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch\": \"BMW\",\n  \"model\": \"330e\"\n}"
            },
            "url": "{{baseUrl}}/api/cars"
          }
        },
        {
          "name": "PUT update car",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch\": \"BMW\",\n  \"model\": \"320i\"\n}"
            },
            "url": "{{baseUrl}}/api/cars/{{carId}}"
          }
        },
        {
          "name": "DELETE car",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cars/{{carId}}"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000"},
    {"key": "bookId", "value": "1"},
    {"key": "carId", "value": "1"}
  ]
}
